generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model agents {
  id                 Int                 @id(map: "agents_pk") @default(autoincrement())
  user               Int?
  status             String?             @db.VarChar(50)
  created_at         DateTime?           @db.Timestamp(6)
  updated_at         DateTime?           @db.Timestamp(6)
  permission         Int?
  agents_permissions agents_permissions? @relation(fields: [permission], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "agents_permissions_fk")
  users              users?              @relation(fields: [user], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "agents_user_fk")
  extensions_agent   extensions_agent[]
}

model agents_permissions {
  id         Int       @id(map: "agents_permissions_pk") @default(autoincrement())
  name       String?   @db.VarChar(50)
  created_at DateTime? @db.Timestamp(6)
  updated_at DateTime? @db.Timestamp(6)
  is_active  Boolean?
  agents     agents[]
}

model clients {
  id           Int        @id(map: "clients_pk") @default(autoincrement())
  first_name   String?    @db.VarChar(120)
  last_name    String?    @db.VarChar(120)
  id_type      String?    @db.VarChar(50)
  id_number    String?    @db.VarChar(50)
  mail         String?    @db.VarChar(120)
  address      String?    @db.VarChar(250)
  created_at   DateTime?  @db.Timestamp(6)
  updated_at   DateTime?  @db.Timestamp(6)
  phone_number String?    @db.VarChar(50)
  supports     supports[]
}

model context_def {
  id         Int          @id @default(autoincrement())
  name       String?      @db.VarChar(120)
  permission String?      @db.VarChar(25)
  is_active  Boolean?
  created_at DateTime?    @db.Time(6)
  updated_at DateTime?    @db.Time(6)
  monitors   String?
  extensions extensions[]
}

model extensions {
  id               Int                @id(map: "extensions_pk") @default(autoincrement())
  identity         String?            @db.VarChar(50)
  is_active        Boolean?
  status           String?            @db.VarChar(50)
  created_at       DateTime?          @db.Timestamp(6)
  updated_at       DateTime?          @db.Timestamp(6)
  password         String?            @db.VarChar(20)
  context          Int?
  access_type      String?            @db.VarChar(25)
  allocated        Boolean?
  context_def      context_def?       @relation(fields: [context], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "extension_context_fk")
  extensions_agent extensions_agent[]
}

model extensions_agent {
  id              Int               @id(map: "extensions_agent_pk") @default(autoincrement())
  agent           Int?
  extension       Int?
  is_active       Boolean?
  created_at      DateTime?         @db.Timestamp(6)
  updated_at      DateTime?         @db.Timestamp(6)
  agents          agents?           @relation(fields: [agent], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "extensions_agent_agent_fk")
  extensions      extensions?       @relation(fields: [extension], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "extensions_agent_extension_fk")
  services_agents services_agents[]
  supports        supports[]
}

model services {
  id                  Int                   @id(map: "services_pk") @default(autoincrement())
  name                String?               @db.VarChar(120)
  status              String?               @db.VarChar(50)
  is_active           Boolean?
  created_at          DateTime?             @db.Timestamp(6)
  updated_at          DateTime?             @db.Timestamp(6)
  retry               Int?
  wrapuptime          Int?
  strategy            String?               @db.VarChar
  timeout             Int?
  identity            String?               @db.VarChar(50)
  services_agents     services_agents[]
  services_categories services_categories[]
  supports            supports[]
}

model services_agents {
  id               Int               @id(map: "services_agents_pk") @default(autoincrement())
  service          Int?
  extension        Int?
  is_active        Boolean?
  created_at       DateTime?         @db.Timestamp(6)
  updated_at       DateTime?         @db.Timestamp(6)
  extensions_agent extensions_agent? @relation(fields: [extension], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "services_agents_extension_fk")
  services         services?         @relation(fields: [service], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "services_agents_service_fk")
}

model services_categories {
  id               Int                @id(map: "services_categories_pk") @default(autoincrement())
  name             String?            @db.VarChar(120)
  service          Int?
  is_active        Boolean?
  created_at       DateTime?          @db.Timestamp(6)
  updated_at       DateTime?          @db.Timestamp(6)
  services         services?          @relation(fields: [service], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "services_categories_service_fk")
  supports_details supports_details[]
}

model supports {
  id               Int                @id(map: "supports_pk") @default(autoincrement())
  agent            Int?
  client           Int?
  status           String?            @db.VarChar(50)
  start_at         DateTime?          @db.Timestamp(6)
  end_at           DateTime?          @db.Timestamp(6)
  observation      String?
  service          Int?
  extensions_agent extensions_agent?  @relation(fields: [agent], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "supports_agent_fk")
  clients          clients?           @relation(fields: [client], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "supports_client_fk")
  services         services?          @relation(fields: [service], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "supports_service_fk")
  supports_details supports_details[]
  supports_records supports_records[]
}

model supports_details {
  id                  Int                  @id(map: "supports_details_pk") @default(autoincrement())
  support             Int?
  service_category    Int?
  observation         String?
  services_categories services_categories? @relation(fields: [service_category], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "supports_details_service_category_fk")
  supports            supports?            @relation(fields: [support], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "supports_details_support_fk")
}

model supports_records {
  id          Int       @id(map: "supports_records_pk") @default(autoincrement())
  url         String?
  created_at  DateTime? @db.Timestamp(6)
  observation String?
  support     Int?
  supports    supports? @relation(fields: [support], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "supports_records_support_fk")
}

model users {
  id           Int          @id(map: "users_pk") @default(autoincrement())
  first_name   String?      @db.VarChar(120)
  last_name    String?      @db.VarChar(120)
  email        String?      @db.VarChar(120)
  phone_number String?      @db.VarChar(50)
  avatar       String?
  created_at   DateTime?    @db.Timestamp(6)
  updated_at   DateTime?    @db.Timestamp(6)
  access_type  String?      @db.VarChar(50)
  agents       agents[]
  users_auth   users_auth[]
}

model users_auth {
  id          Int      @id(map: "users_auth_pk") @default(autoincrement())
  username    String?  @db.VarChar(50)
  password    String?
  is_active   Boolean?
  is_verified Boolean?
  status      String?  @db.VarChar(120)
  user        Int?
  users       users?   @relation(fields: [user], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "users_auth_user_fk")
}

model core_updates_log {
  id         Int       @id(map: "core_updates_log_pk") @default(autoincrement())
  action     String?   @db.VarChar(50)
  status     String?   @db.VarChar(25)
  created_at DateTime? @db.Time(6)
  updated_at DateTime? @db.Time(6)
  users      String?   @db.VarChar
  identity   Int?
  reference  String?   @db.VarChar(50)
}
